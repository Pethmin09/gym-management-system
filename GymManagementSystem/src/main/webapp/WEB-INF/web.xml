<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">


    <!-- ADD -->
    <servlet>
        <servlet-name>Add</servlet-name>
        <servlet-class>com.gym.servlet.AddEquipmentServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>Add</servlet-name>
        <url-pattern>/addEquipment</url-pattern>
    </servlet-mapping>

    <!-- DELETE -->
    <servlet>
        <servlet-name>Delete</servlet-name>
        <servlet-class>com.gym.servlet.DeleteEquipmentServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>Delete</servlet-name>
        <url-pattern>/delete</url-pattern>
    </servlet-mapping>

    <!-- UPDATE -->
    <servlet>
        <servlet-name>Update</servlet-name>
        <servlet-class>com.gym.servlet.UpdateEquipmentServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>Update</servlet-name>
        <url-pattern>/update</url-pattern>
    </servlet-mapping>

</web-app>